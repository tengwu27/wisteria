---
interface NavItem {
  slug: string;
  data: {
    title: string;
  };
}

interface Props {
  previous?: NavItem;
  next?: NavItem;
  basePath: string;
}

const { previous, next, basePath } = Astro.props;
---

<nav class="grid gap-4 border-t border-mist pt-8 md:grid-cols-2" aria-label="上一篇与下一篇">
  <div>
    {previous && (
      <a class="group block" href={`${basePath}/${previous.slug}`}>
        <span class="text-xs uppercase tracking-[0.18em] text-ash">上一篇</span>
        <span class="mt-2 block font-serif text-2xl text-ink group-hover:underline">{previous.data.title}</span>
      </a>
    )}
  </div>
  <div class="md:text-right">
    {next && (
      <a class="group block" href={`${basePath}/${next.slug}`}>
        <span class="text-xs uppercase tracking-[0.18em] text-ash">下一篇</span>
        <span class="mt-2 block font-serif text-2xl text-ink group-hover:underline">{next.data.title}</span>
      </a>
    )}
  </div>
</nav>
