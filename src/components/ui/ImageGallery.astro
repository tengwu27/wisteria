---
import { getMedia, type MediaKey } from '@/assets/images/placeholders';

interface GalleryItem {
  imageKey: MediaKey;
  alt: string;
  caption?: string;
}

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <div class="grid gap-5 md:grid-cols-2">
    {items.map((item) => (
      <figure class="reveal">
        <img
          class="aspect-[4/3] w-full bg-mist object-cover"
          src={getMedia(item.imageKey)}
          alt={item.alt}
          loading="lazy"
          decoding="async"
        />
        {item.caption && <figcaption class="mt-3 text-sm leading-6 text-ash">{item.caption}</figcaption>}
      </figure>
    ))}
  </div>
)}
