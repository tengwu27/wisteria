---
import type { CollectionEntry } from 'astro:content';
import { getMedia } from '@/assets/images/placeholders';

interface Props {
  entry: CollectionEntry<'travel'>;
}

const { entry } = Astro.props;
---

<a class="group block bg-paper" href={`/travel/${entry.slug}`}>
  <img
    class="aspect-[4/3] w-full bg-mist object-cover transition duration-700 group-hover:scale-[1.02]"
    src={getMedia(entry.data.coverImage)}
    alt={entry.data.coverAlt}
    loading="lazy"
    decoding="async"
  />
  <div class="pt-5">
    <p class="text-xs uppercase tracking-[0.18em] text-ash">{entry.data.year} / {entry.data.country}</p>
    <h2 class="mt-2 font-serif text-3xl leading-tight text-ink group-hover:underline">{entry.data.destination}</h2>
    <p class="mt-3 text-sm leading-6 text-graphite">{entry.data.excerpt}</p>
  </div>
</a>
