---
import { getMedia, type MediaKey } from '@/assets/images/placeholders';

interface Props {
  title: string;
  href: string;
  imageKey: MediaKey;
  alt: string;
  meta?: string;
  excerpt?: string;
  large?: boolean;
}

const { title, href, imageKey, alt, meta, excerpt, large = false } = Astro.props;
---

<a class={`group block ${large ? 'md:col-span-2' : ''}`} href={href}>
  <div class="media-frame overflow-hidden bg-mist shadow-soft">
    <img
      class={`w-full object-cover transition duration-700 group-hover:scale-[1.03] ${large ? 'aspect-[16/9]' : 'aspect-[4/5]'}`}
      src={getMedia(imageKey)}
      alt={alt}
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="mt-5 max-w-2xl">
    {meta && <p class="text-xs font-black uppercase tracking-[0.16em] text-accent">{meta}</p>}
    <h2 class="mt-2 font-sans text-4xl font-black leading-none text-ink group-hover:underline md:text-6xl">{title}</h2>
    {excerpt && <p class="mt-4 text-base font-semibold leading-7 text-graphite">{excerpt}</p>}
  </div>
</a>
