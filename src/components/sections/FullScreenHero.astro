---
import { getMedia } from '@/assets/images/placeholders';
import { site } from '@/data/site';

const hero = site.hero;
---

<section class="relative min-h-screen overflow-hidden bg-ink text-paper">
  <img
    class="hero-drift absolute inset-0 h-full w-full object-cover opacity-90"
    src={getMedia(hero.imageKey)}
    alt="Replaceable full-screen hero placeholder"
    fetchpriority="high"
    decoding="async"
  />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(28,26,23,0.70),rgba(28,26,23,0.20)_48%,rgba(28,26,23,0.10))]"></div>
  <div class="relative mx-auto flex min-h-screen max-w-7xl items-end px-6 pb-20 pt-28 lg:px-8">
    <div class="max-w-3xl reveal">
      <h1 class="font-serif text-6xl leading-[0.95] md:text-8xl">{hero.title}</h1>
      <p class="mt-6 max-w-xl text-lg leading-8 text-paper/78">{hero.subtitle}</p>
      <a class="mt-12 inline-flex text-xs uppercase tracking-[0.22em] text-paper/70 transition hover:text-paper" href="#introduction">
        Scroll
      </a>
    </div>
  </div>
</section>
