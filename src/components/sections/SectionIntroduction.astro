---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<section class="px-6 py-20 lg:px-8">
  <div class="mx-auto max-w-5xl">
    {eyebrow && <p class="text-xs uppercase tracking-[0.22em] text-accent">{eyebrow}</p>}
    <h1 class="mt-4 max-w-4xl font-serif text-5xl leading-[1.02] text-ink md:text-7xl">{title}</h1>
    {text && <p class="mt-8 max-w-3xl text-lg leading-8 text-graphite">{text}</p>}
  </div>
</section>
