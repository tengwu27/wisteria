---
import { site } from '@/data/site';
---

<section class="bg-ink px-6 py-20 text-paper lg:px-8">
  <div class="mx-auto max-w-5xl text-center">
    <p class="text-sm uppercase tracking-[0.22em] text-brass">Private advisory</p>
    <h2 class="mt-5 font-serif text-4xl leading-tight md:text-6xl">Bring the next chapter into focus.</h2>
    <p class="mx-auto mt-6 max-w-2xl text-base leading-7 text-paper/70">
      {site.name} helps clients shape property decisions, capital strategy, and design direction as one coherent lifestyle investment.
    </p>
    <a class="mt-9 inline-flex rounded-sm bg-paper px-6 py-3 text-sm font-semibold text-ink transition hover:bg-stone" href="/contact">
      Connect with Wisteria
    </a>
  </div>
</section>
