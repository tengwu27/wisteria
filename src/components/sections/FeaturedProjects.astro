---
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section id="projects" class="bg-paper px-6 py-20 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <p class="text-sm uppercase tracking-[0.22em] text-brass">Featured work</p>
      <h2 class="mt-4 font-serif text-4xl leading-tight text-ink md:text-5xl">Opportunities shaped with capital, context, and taste.</h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {projects.map((project) => (
        <article class="border border-stone bg-white p-6 shadow-soft">
          <p class="text-xs uppercase tracking-[0.18em] text-moss">{project.data.category}</p>
          <h3 class="mt-5 font-serif text-2xl text-ink">{project.data.title}</h3>
          <p class="mt-4 text-sm leading-6 text-graphite">{project.data.summary}</p>
          <p class="mt-8 text-sm text-graphite/70">{project.data.location}</p>
        </article>
      ))}
    </div>
  </div>
</section>
