---
import { services } from '@/data/services';
---

<section id="services" class="bg-white px-6 py-20 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <p class="text-sm uppercase tracking-[0.22em] text-brass">Practice pillars</p>
      <h2 class="mt-4 font-serif text-4xl leading-tight text-ink md:text-5xl">A connected view of place, value, atmosphere, and life.</h2>
    </div>
    <div class="mt-12 grid gap-px overflow-hidden border border-stone bg-stone md:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <article class="bg-paper p-6">
          <p class="font-serif text-3xl text-ink">{service.title}</p>
          <p class="mt-4 text-sm leading-6 text-graphite">{service.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
