---
import { navigation } from '@/data/navigation';
import { site } from '@/data/site';
---

<footer class="bg-ink text-paper">
  <div class="mx-auto grid max-w-7xl gap-12 px-6 py-14 md:grid-cols-[1.4fr_1fr] lg:px-8">
    <div>
      <a href="/" class="font-serif text-3xl tracking-normal">{site.name}</a>
      <p class="mt-4 max-w-xl text-sm leading-6 text-paper/70">{site.tagline}</p>
      <p class="mt-8 text-xs uppercase tracking-[0.18em] text-paper/45">All names, dates, places, and images are placeholders until replaced.</p>
    </div>
    <nav class="grid gap-3 text-sm text-paper/70 md:justify-end md:text-right" aria-label="Footer navigation">
      {navigation.map((item) => (
        <a class="transition hover:text-paper" href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</footer>
