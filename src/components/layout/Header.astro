---
import { navigation } from '@/data/navigation';
import { site } from '@/data/site';
---

<header class="sticky top-0 z-40 border-b border-stone/80 bg-paper/90 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <a href="/" class="font-serif text-2xl text-ink">{site.name}</a>
    <nav class="hidden items-center gap-8 text-sm font-medium text-graphite md:flex" aria-label="Primary navigation">
      {navigation.map((item) => (
        <a class="transition hover:text-ink" href={item.href}>{item.label}</a>
      ))}
    </nav>
    <a class="rounded-sm bg-ink px-4 py-2 text-sm font-semibold text-paper transition hover:bg-graphite" href="/contact">
      Start a Conversation
    </a>
  </div>
</header>
