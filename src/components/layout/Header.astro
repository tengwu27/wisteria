---
import { navigation } from '@/data/navigation';
import { site } from '@/data/site';
---

<header class="fixed inset-x-0 top-0 z-40 bg-paper/78 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8">
    <a href="/" class="font-serif text-xl text-ink md:text-2xl">{site.name}</a>
    <nav class="hidden items-center gap-8 text-xs uppercase tracking-[0.18em] text-graphite md:flex" aria-label="Primary navigation">
      {navigation.map((item) => (
        <a class="transition hover:text-ink" href={item.href}>{item.label}</a>
      ))}
    </nav>
    <a class="text-xs uppercase tracking-[0.18em] text-graphite transition hover:text-ink md:hidden" href="/about">
      About
    </a>
  </div>
</header>
