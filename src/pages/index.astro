---
import { getCollection } from 'astro:content';
import ArtCard from '@/components/ui/ArtCard.astro';
import FullScreenHero from '@/components/sections/FullScreenHero.astro';
import LifestyleCard from '@/components/ui/LifestyleCard.astro';
import MarqueeBand from '@/components/ui/MarqueeBand.astro';
import MediaCard from '@/components/ui/MediaCard.astro';
import TravelCard from '@/components/ui/TravelCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { homeChapters } from '@/data/services';
import { byNewest, byOrder } from '@/utils/content';

const art = (await getCollection('art')).filter((entry) => entry.data.published).sort(byOrder);
const lifestyle = (await getCollection('lifestyle')).filter((entry) => entry.data.published).sort(byNewest);
const travel = (await getCollection('travel')).filter((entry) => entry.data.published).sort(byNewest);
---

<BaseLayout>
  <FullScreenHero />
  <section id="introduction" class="relative overflow-hidden bg-milk px-6 py-24 lg:px-8">
    <div class="absolute right-8 top-10 hidden rotate-6 font-mono text-sm text-accent md:block">让它属于你们</div>
    <div class="mx-auto max-w-5xl text-center">
      <p class="intro-statement text-balance font-sans text-4xl font-black leading-tight text-ink md:text-6xl">
        这里收藏着我们
        <span class="hero-highlight hero-highlight--green">去过的地方</span>、亲手
        <span class="font-serif italic font-semibold">做过的事</span>，以及塑造我们的时刻。
      </p>
      <p class="mx-auto mt-8 max-w-2xl text-base font-semibold leading-7 text-graphite">随着档案慢慢成为你们自己的，把文字、图片、日期和地点都换成真实内容。</p>
    </div>
  </section>
  <section class="relative overflow-hidden px-6 pb-24 pt-8 lg:px-8">
    <div class="-mx-6 mb-20 rotate-1 lg:-mx-8">
      <MarqueeBand
        tone="light"
        reverse
        items={['画下仍在心里的东西', '收好票根', '写下那天的天气', '收藏平凡日常']}
        label="档案提示"
      />
    </div>
    <div class="mx-auto grid max-w-7xl gap-16">
      {homeChapters.map((chapter, index) => (
        <div class={`chapter-row grid items-end gap-8 md:grid-cols-2 ${index % 2 === 1 ? 'md:[&>*:first-child]:order-2' : ''}`}>
          <MediaCard
            title={chapter.title}
            href={chapter.href}
            imageKey={chapter.imageKey}
            alt={`${chapter.title}章节占位图`}
            excerpt={chapter.description}
            large
          />
        </div>
      ))}
    </div>
  </section>
  <section class="bg-[#fff0f2] px-6 py-24 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-3">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.16em] text-accent">最近放入</p>
        <h2 class="mt-4 font-sans text-4xl font-black leading-tight text-ink">从<span class="font-serif italic font-semibold">档案</span>里选出的几件。</h2>
      </div>
      {art[0] && <ArtCard entry={art[0]} />}
      {lifestyle[0] && <LifestyleCard entry={lifestyle[0]} />}
      {travel[0] && <TravelCard entry={travel[0]} />}
    </div>
  </section>
</BaseLayout>
