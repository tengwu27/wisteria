---
import { getCollection } from 'astro:content';
import ArtGallery from '@/components/sections/ArtGallery.astro';
import SectionIntroduction from '@/components/sections/SectionIntroduction.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { byOrder } from '@/utils/content';

const entries = (await getCollection('art')).filter((entry) => entry.data.published).sort(byOrder);
---

<BaseLayout title="艺术 | 我们的生活收藏" description="一组安静的视觉档案，收藏作品、习作、照片与实验。">
  <div class="pt-20">
    <SectionIntroduction
      eyebrow="艺术"
      title="随时间聚拢的作品、习作与实验。"
      text="这个画廊适合收纳不同尺寸的作品、过程图片、文字故事、标签，以及未来新增的分类。"
    />
    <ArtGallery entries={entries} />
  </div>
</BaseLayout>
