---
import { getCollection } from 'astro:content';
import ArtGallery from '@/components/sections/ArtGallery.astro';
import SectionIntroduction from '@/components/sections/SectionIntroduction.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { byOrder } from '@/utils/content';

const entries = (await getCollection('art')).filter((entry) => entry.data.published).sort(byOrder);
---

<BaseLayout title="Art | Our Life, Collected" description="A quiet visual portfolio of works, studies, photographs, and experiments.">
  <div class="pt-20">
    <SectionIntroduction
      eyebrow="Art"
      title="Works, studies, and experiments gathered over time."
      text="This gallery is structured for mixed proportions, process images, written stories, tags, and future categories."
    />
    <ArtGallery entries={entries} />
  </div>
</BaseLayout>
