---
import { getCollection } from 'astro:content';
import SectionIntroduction from '@/components/sections/SectionIntroduction.astro';
import TravelTimeline from '@/components/sections/TravelTimeline.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { byNewest } from '@/utils/content';

const entries = (await getCollection('travel')).filter((entry) => entry.data.published).sort(byNewest);
---

<BaseLayout title="旅行 | 我们的生活收藏" description="一段按时间展开的视觉旅程，经过地点、季节与共同记忆。">
  <div class="pt-20">
    <SectionIntroduction
      eyebrow="旅行"
      title="按时间经过地点与季节。"
      text="在桌面端，旅行条目会沿着中轴线交错排列；在移动端，时间线会变成单侧布局，阅读更清晰。"
    />
    <TravelTimeline entries={entries} />
  </div>
</BaseLayout>
