---
import { getCollection } from 'astro:content';
import ContentRenderer from '@/components/ui/ContentRenderer.astro';
import ImageGallery from '@/components/ui/ImageGallery.astro';
import PreviousNextNavigation from '@/components/ui/PreviousNextNavigation.astro';
import { getMedia } from '@/assets/images/placeholders';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { byNewest, findPreviousNext, formatDate } from '@/utils/content';

export async function getStaticPaths() {
  const entries = (await getCollection('travel')).filter((entry) => entry.data.published).sort(byNewest);

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, entries }
  }));
}

const { entry, entries } = Astro.props;
const { Content } = await entry.render();
const { previous, next } = findPreviousNext(entries, entry.slug);
const dateRange = entry.data.endDate ? `${formatDate(entry.data.startDate)} - ${formatDate(entry.data.endDate)}` : formatDate(entry.data.startDate);
---

<BaseLayout title={`${entry.data.destination} | 旅行`} description={entry.data.excerpt} type="article">
  <article class="pt-20">
    <header class="px-6 py-16 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <p class="text-xs uppercase tracking-[0.22em] text-accent">{entry.data.year} / {entry.data.country}</p>
        <h1 class="mt-5 font-serif text-5xl leading-[1.02] text-ink md:text-7xl">{entry.data.destination}</h1>
        <p class="mt-6 text-sm uppercase tracking-[0.16em] text-ash">{dateRange}</p>
        <p class="mt-7 max-w-3xl text-lg leading-8 text-graphite">{entry.data.excerpt}</p>
      </div>
    </header>
    <figure class="mx-auto max-w-7xl px-6 lg:px-8">
      <img class="aspect-[16/10] w-full bg-mist object-cover" src={getMedia(entry.data.coverImage)} alt={entry.data.coverAlt} />
    </figure>
    <div class="mx-auto grid max-w-5xl gap-12 px-6 py-16 lg:px-8">
      <ContentRenderer><Content /></ContentRenderer>
      {entry.data.highlights.length > 0 && (
        <section>
          <h2 class="font-serif text-4xl text-ink">记忆亮点</h2>
          <ul class="mt-5 grid gap-3 text-graphite">
            {entry.data.highlights.map((highlight) => <li class="border-l border-accent pl-4">{highlight}</li>)}
          </ul>
        </section>
      )}
      <ImageGallery items={entry.data.gallery} />
      <PreviousNextNavigation previous={previous} next={next} basePath="/travel" />
    </div>
  </article>
</BaseLayout>
